---
// MarkdownPostLayout.astro — a single blog entry, set as a printed page.
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/almanac/Header.astro';
import Footer from '~/components/almanac/Footer.astro';
import RuleOrn from '~/components/almanac/RuleOrn.astro';
import Button from '~/components/almanac/Button.astro';
import PostImage from '~/components/almanac/PostImage.astro';
import { formatLongDate, tagHref } from '~/utils/blog';
import type { Post } from '~/utils/blog';

interface Props {
  post: Post;
  readingTime?: number;
}
const { post, readingTime } = Astro.props;
const { title, excerpt, publishDate, category, tags = [], image } = post.data;
---

<Layout title={title} description={excerpt}>
  <Header />
  <main class="wrap post">
    <a class="back" href="/blog">← Blog</a>
    <article>
      <header class="post-head">
        <div class="meta">
          {publishDate && <span class="eyebrow">{formatLongDate(publishDate)}</span>}
          {category && <span class="eyebrow sub">{category}</span>}
          {readingTime ? <span class="eyebrow sub">{readingTime} min read</span> : null}
        </div>
        <h1 class="display post-title">{title}</h1>
        {excerpt && <p class="lede">{excerpt}</p>}
        <RuleOrn style="max-width:24rem;margin:1.6rem auto 0" />
      </header>

      {
        image && (
          <figure class="post-figure">
            <PostImage
              src={image}
              alt={title}
              widths={[480, 768, 1024]}
              sizes="(max-width: 720px) 92vw, 680px"
              loading="eager"
            />
          </figure>
        )
      }

      <div class="prose">
        <slot />
      </div>

      {
        tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => (
              <a class="tag label" href={tagHref(t)}>
                {t}
              </a>
            ))}
          </div>
        )
      }
    </article>

    <div class="post-foot">
      <Button href="/blog">Back to Blog</Button>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .post {
    padding-block: clamp(1.6rem, 4vw, 3rem) 0;
    max-width: min(72ch, 92vw);
  }
  .back {
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: var(--tracking-nav);
    font-size: var(--text-nav);
    color: var(--color-ink-faint);
  }
  .back:hover {
    color: var(--color-accent);
  }
  .post-head {
    margin: 1.6rem 0 2.2rem;
  }
  .meta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--text-eyebrow);
    color: var(--color-accent);
  }
  .eyebrow.sub {
    text-transform: none;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--color-ink-faint);
  }
  .post-title {
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    margin: 0;
  }
  .lede {
    font-size: var(--text-body-lg);
    color: var(--color-ink-soft);
    font-style: italic;
    margin: 1rem 0 0;
  }
  /* medium, engraved-framed lead image */
  .post-figure {
    margin: 2rem 0 0;
  }
  .post-figure :global(img) {
    display: block;
    width: 100%;
    max-height: 26rem;
    object-fit: cover;
    border: 1px solid var(--color-rule);
    box-shadow:
      inset 0 0 0 3px var(--color-paper),
      inset 0 0 0 4px color-mix(in oklab, var(--color-rule) 45%, transparent);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
  }
  .tag {
    border: 1px solid var(--color-line);
    padding: 0.25rem 0.6rem;
    color: var(--color-ink-faint);
    transition:
      color 0.2s,
      border-color 0.2s;
  }
  a.tag:hover {
    color: var(--color-accent);
    border-color: color-mix(in oklab, var(--color-accent) 55%, transparent);
  }
  .post-foot {
    margin: 3rem 0 4rem;
  }
</style>

---
// MarkdownLayout.astro — standalone markdown pages (privacy, terms, …).
// Used via frontmatter:  layout: '~/layouts/MarkdownLayout.astro'
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/almanac/Header.astro';
import Footer from '~/components/almanac/Footer.astro';
import RuleOrn from '~/components/almanac/RuleOrn.astro';

const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? 'Document';
---

<Layout title={title} noindex>
  <Header />
  <main class="wrap doc">
    <h1 class="display doc-title">{title}</h1>
    <RuleOrn style="max-width:24rem;margin:1.4rem auto 2.2rem" />
    <article class="prose">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .doc {
    padding-block: clamp(1.6rem, 4vw, 3rem) 4rem;
    max-width: min(72ch, 92vw);
  }
  .doc-title {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    margin: 0;
  }
</style>

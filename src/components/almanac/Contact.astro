---
// Contact.astro — the closing colour-block in the rail layout: numeral up the
// left gutter, centred ❦ crest, "Let's Talk", and invert/ghost actions.
import SectionAside from './SectionAside.astro';
import Button from './Button.astro';
import { MEET_URL } from '~/data/site';
---

<section class="section cta cta--bold" id="contact">
  <div class="wrap sec-grid">
    <SectionAside no="No. 4" title="Contact" />
    <div class="sec-body" style="position:relative;text-align:center">
      <div class="reveal">
        <div class="cta-orn" aria-hidden="true">❦</div>
        <h2 class="display">Let’s Talk</h2>
        <p class="tagline" style="margin:0 auto;max-width:34ch">Send a word</p>
        <div class="links">
          <Button href="/contact" variant="invert" arrow={false}>Contact Me</Button>
          <Button href={MEET_URL} variant="ghost" arrow={false} target="_blank" rel="noopener">Meet With Me</Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* warm white "Let's Talk" on the colour-block on every theme */
  #contact.cta--bold h2 {
    color: var(--color-cta-ink);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.22);
  }
</style>

// engraved-monogram fallback for any social without an SVG logo
const GLYPHS: Record<string, string> = {};

const svg = LOGOS[name];
const glyph = GLYPHS[name];
---

<a class="social" href={href} target="_blank" rel="noopener" aria-label={name}>
  {svg ? <Fragment set:html={svg} /> : <span class="glyph">{glyph}</span>}
  <span class="tip" aria-hidden="true">{name}</span>
</a>

<style>
  .social {
    position: relative;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex: none;
    color: var(--color-ink-soft);
    background: color-mix(in oklab, var(--color-paper-2) 55%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-gold) 50%, transparent);
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 2px color-mix(in oklab, var(--color-paper) 70%, transparent),
      inset 0 0 0 3px color-mix(in oklab, var(--color-gold) 18%, transparent);
    transition:
      color 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }
  .social:hover {
    color: var(--color-accent);
    border-color: color-mix(in oklab, var(--color-accent) 60%, transparent);
    transform: translateY(-2px);
  }
  .social :global(svg) {
    display: block;
    width: 17px;
    height: 17px;
    fill: currentColor;
  }
  .glyph {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1;
    font-style: italic;
  }

  .tip {
    position: absolute;
    bottom: calc(100% + 9px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 0.32rem 0.55rem;
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.64rem;
    line-height: 1;
    white-space: nowrap;
    color: var(--color-paper);
    background: var(--color-ink);
    border: 1px solid color-mix(in oklab, var(--color-gold) 55%, transparent);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.28);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 60;
    transition:
      opacity 0.18s,
      transform 0.18s,
      visibility 0.18s;
  }
  .tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    width: 7px;
    height: 7px;
    margin-top: -4px;
    background: var(--color-ink);
    border-right: 1px solid color-mix(in oklab, var(--color-gold) 55%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--color-gold) 55%, transparent);
    transform: translateX(-50%) rotate(45deg);
  }
  .social:hover .tip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
</style>

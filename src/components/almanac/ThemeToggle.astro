---
// ThemeToggle.astro — gilt circle button that flips Parchment ⇄ Midnight
// and persists the choice. Pairs with ThemeScript.astro.
---

<button class="head-btn" id="theme-toggle" type="button" aria-label="Toggle colour theme">
  <span aria-hidden="true" data-icon>☾</span>
</button>

<style>
  .head-btn {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    flex: none;
    padding: 0;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1;
    color: var(--color-gold);
    cursor: pointer;
    background: color-mix(in oklab, var(--color-paper-2) 55%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-gold) 55%, transparent);
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 2px color-mix(in oklab, var(--color-paper) 70%, transparent),
      inset 0 0 0 3px color-mix(in oklab, var(--color-gold) 20%, transparent);
    transition:
      color 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }
  .head-btn:hover {
    color: var(--color-accent);
    border-color: color-mix(in oklab, var(--color-accent) 60%, transparent);
    transform: translateY(-1px);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const icon = btn?.querySelector('[data-icon]');
  const sync = () => {
    if (icon) icon.textContent = document.documentElement.dataset.palette === 'midnight' ? '☀' : '☾';
  };
  sync();
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.palette === 'midnight' ? 'parchment' : 'midnight';
    document.documentElement.dataset.palette = next;
    try {
      localStorage.setItem('almanac-theme', next);
    } catch {
      /* ignore */
    }
    sync();
  });
</script>

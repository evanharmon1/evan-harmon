---
// Projects.astro — the "Work" catalogue in the rail layout, on a tinted band,
// closed with an inter-section flourish.
import SectionAside from './SectionAside.astro';
import Flourish from './Flourish.astro';
import { PROJECTS } from '~/data/site';
---

<section class="section section--tint" id="projects">
  <div class="wrap sec-grid">
    <SectionAside no="No. 2" title="Work" />
    <div class="sec-body">
      <div class="catalog">
        {
          PROJECTS.map((p, i) => (
            <a
              class="entry reveal"
              href={p.href}
              target={p.href.startsWith('http') ? '_blank' : undefined}
              rel={p.href.startsWith('http') ? 'noopener' : undefined}
            >
              <div class="no">{i + 1}</div>
              <div>
                <h3 class="display">
                  {p.title}
                  <span class="arw" aria-hidden="true">
                    →
                  </span>
                </h3>
                <p>{p.description}</p>
                <div class="tag label">{p.kind}</div>
              </div>
              <span class="seal" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14">
                  <g
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="7" y1="17" x2="16.5" y2="7.5" />
                    <polyline points="9.5,7 17,7 17,14.5" />
                  </g>
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <Flourish glyph="❖" />
</section>

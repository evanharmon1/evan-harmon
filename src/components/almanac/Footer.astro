---
// Footer.astro — wordmark, the social "machines" row, a closing rule + foot-note.
import SocialIcon from './SocialIcon.astro';
import RuleOrn from './RuleOrn.astro';
import { SITE, SOCIALS } from '~/data/site';
---

<footer class="site-foot">
  <div class="wrap">
    <div class="foot-grid">
      <div style="max-width:22rem">
        <div class="brand-word">Evan Harmon</div>
      </div>
      <div>
        <div class="label">Elsewhere on the machines</div>
        <div class="socials">
          {SOCIALS.map((s) => <SocialIcon name={s.name} href={s.href} />)}
        </div>
      </div>
    </div>
    <RuleOrn style="margin:2.5rem 0 0" />
    <p class="foot-note">{SITE.tagline}</p>
    <p class="foot-brandlink">
      <a href="/brand">The Design ❧</a>
    </p>
  </div>
</footer>

<style>
  .brand-word {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
  }
  .foot-brandlink {
    text-align: center;
    margin: 0.4rem 0 0;
  }
  .foot-brandlink a {
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: var(--tracking-nav);
    font-size: 0.7rem;
    color: var(--color-ink-faint);
  }
  .foot-brandlink a:hover {
    color: var(--color-accent);
  }
</style>

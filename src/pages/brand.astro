<script is:inline>
  // OG-card preview follows the theme toggle.
  (function () {
    const img = document.getElementById('ogImg');
    const title = document.getElementById('ogTitle');
    const path = document.getElementById('ogPath');
    if (!img) return;
    const sync = () => {
      const dark = document.documentElement.dataset.palette === 'midnight';
      const src = dark ? '/images/og-image.png' : '/images/og-image-light.png';
      img.setAttribute('src', src);
      if (title) title.textContent = dark ? 'Midnight · default' : 'Parchment · green block';
      if (path) path.textContent = src + ' · 1200×630';
    };
    sync();
    new MutationObserver(sync).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-palette'],
    });
  })();
</script>


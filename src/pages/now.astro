---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/almanac/Header.astro';
import Footer from '~/components/almanac/Footer.astro';
import PageHeading from '~/components/almanac/PageHeading.astro';
import PostImage from '~/components/almanac/PostImage.astro';
import RuleOrn from '~/components/almanac/RuleOrn.astro';
---

<Layout title="Now" description="What Evan Harmon is reading, doing, making, and enjoying right now.">
  <Header />
  <main class="section">
    <div class="wrap now">
      <PageHeading title="Now" sub="What I'm up to lately" center />

      <figure class="now-figure">
        <PostImage
          src="~/assets/images/flammarion.jpeg"
          alt="The Flammarion engraving — a traveller peers through the edge of the firmament"
          widths={[320, 462]}
          sizes="(max-width: 540px) 80vw, 420px"
          loading="eager"
        />
        <figcaption class="now-figcap" role="tooltip">
          <span class="cap-t">The Flammarion Engraving</span>
          <span class="cap-d"
            >Often interpreted as a symbol of curiosity, scientific discovery, or breaking through an old worldview.</span
          >
          <span class="cap-m">Artist unknown · 1888</span>
        </figcaption>
      </figure>

      <p class="now-intro">
        This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener">now page</a>, and if you have
        your own site you should make one too.
      </p>

      <RuleOrn style="max-width:24rem;margin:0 auto 2.4rem" />

      <article class="prose now-body">
        <h3>Reading</h3>
        <ul>
          <li>
            <a href="https://en.wikipedia.org/wiki/Dune_Messiah" target="_blank" rel="noopener"
              >Dune Messiah by Frank Herbert</a
            >
          </li>
          <li>
            <a href="https://calnewport.com/my-new-book-slow-productivity/" target="_blank" rel="noopener"
              >Slow Productivity by Cal Newport</a
            >
          </li>
        </ul>

        <h4>Recently read</h4>
        <ul>
          <li>
            Re-read <a
              href="https://en.wikipedia.org/wiki/A_Heartbreaking_Work_of_Staggering_Genius"
              target="_blank"
              rel="noopener">A Heartbreaking Work of Staggering Genius by Dave Eggers</a
            >: Feels like my generation's <a
              href="https://en.wikipedia.org/wiki/The_Catcher_in_the_Rye"
              target="_blank"
              rel="noopener">The Catcher in the Rye</a
            >
          </li>
        </ul>

        <h3>Doing</h3>
        <ul>
          <li>
            Using <a href="https://obsidian.md/" target="_blank" rel="noopener">Obsidian</a> as my <a
              href="https://www.buildingasecondbrain.com/"
              target="_blank"
              rel="noopener">second brain</a
            > and <a href="https://nesslabs.com/digital-garden-set-up" target="_blank" rel="noopener">digital garden</a
            >. I call mine <a href="https://publish.obsidian.md/evanharmon/Memex" target="_blank" rel="noopener"
              >Memex</a
            >
          </li>
          <li>
            Coding for <a href="https://ponderous.dev" target="_blank" rel="noopener">Ponderous Development</a>
          </li>
          <li>Working on <a href="https://sommerlawn.com" target="_blank" rel="noopener">Sommer Lawn</a></li>
          <li>
            Revamping my <a href="https://linuxhandbook.com/homelab/" target="_blank" rel="noopener">homelab</a> and self-hosted
            infrastructure
          </li>
        </ul>

        <h4>Making</h4>
        <ul>
          <li>
            Building and upgrading my PCs, <a
              href="https://pcpartpicker.com/user/telosmachina/saved/#view=nDZXYJ"
              target="_blank"
              rel="noopener">Contraption</a
            > and <a href="https://pcpartpicker.com/user/telosmachina/saved/#view=qjHqBm" target="_blank" rel="noopener"
              >TARS</a
            >
          </li>
          <li>
            Building a <a
              href="https://the-diy-life.com/introducing-lab-rax-a-3d-printable-modular-10-rack-system/"
              target="_blank"
              rel="noopener">LabRax homelab server</a
            >
          </li>
        </ul>

        <h4>Learning</h4>
        <ul>
          <li>
            <a href="https://en.wikipedia.org/wiki/IndieWeb" target="_blank" rel="noopener">The IndieWeb</a>: (like this
            /now page and <a href="https://home.omg.lol/" target="_blank" rel="noopener">omg.lol</a>!)
          </li>
          <li><a href="https://astro.build/" target="_blank" rel="noopener">Astro Web Framework</a></li>
          <li><a href="https://tanstack.com/" target="_blank" rel="noopener">TanStack Application Framework</a></li>
          <li><a href="https://www.convex.dev/" target="_blank" rel="noopener">Convex Platform</a></li>
          <li>Design</li>
        </ul>

        <h3>Listening</h3>
        <ul>
          <li>
            <a
              href="https://music.apple.com/us/album/kaleidoscope-feat-crystalline/1450404652?i=1450404813"
              target="_blank"
              rel="noopener">Champagne Drip — Kaleidoscope</a
            >
          </li>
          <li>
            <a href="https://youtu.be/tX1znPfzhVI?si=1kWgKNxDego3inZL" target="_blank" rel="noopener"
              >Jesse Morris: Sunday Morning Coming Down</a
            >
          </li>
        </ul>

        <h3>Playing</h3>
        <ul>
          <li><a href="https://arcraiders.com/" target="_blank" rel="noopener">Arc Raiders</a></li>
        </ul>

        <h3>Watching</h3>
        <ul>
          <li>
            Old Norm MacDonald <a
              href="https://www.youtube.com/watch?v=1hu2tJtmCfw&list=PLYSaCq9q-ciQaKzbpx1VAUmzLV-BHkJ8o&index=25"
              target="_blank"
              rel="noopener">clips</a
            >. Love that ol' <a href="https://www.youtube.com/watch?v=-3AqPMV7TWE" target="_blank" rel="noopener"
              >chunk a coal</a
            >
          </li>
          <li>
            <a href="https://en.wikipedia.org/wiki/Widow%27s_Bay" target="_blank" rel="noopener">Widow's Bay</a>
          </li>
          <li><a href="https://en.wikipedia.org/wiki/Scot_Squad" target="_blank" rel="noopener">Scot Squad</a></li>
        </ul>

        <h3>Laughing</h3>
        <ul>
          <li>
            <a
              href="https://www.youtube.com/watch?v=VFevH5vP32s&list=PLYSaCq9q-ciQaKzbpx1VAUmzLV-BHkJ8o&index=75"
              target="_blank"
              rel="noopener">Orson Welles drunk outtakes for a wine commercial</a
            >
          </li>
          <li>
            <a
              href="https://www.youtube.com/watch?v=ZLyNWMI1rEk&list=PLYSaCq9q-ciQaKzbpx1VAUmzLV-BHkJ8o&index=53"
              target="_blank"
              rel="noopener">A Normal Person Explains Cryptocurrency</a
            >
          </li>
          <li>
            <a
              href="https://www.youtube.com/watch?v=0O95kvMKPeQ&list=PLYSaCq9q-ciQaKzbpx1VAUmzLV-BHkJ8o&index=68"
              target="_blank"
              rel="noopener">You Expect Me To Believe That?!? (Ft. Tim Robinson)</a
            >
          </li>
        </ul>

        <h3>Enjoying</h3>
        <ul>
          <li>Time with friends and family, talking, reminiscing</li>
        </ul>
      </article>

      <p class="now-updated">Last updated 2 June 2026.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .now {
    max-width: min(72ch, 92vw);
  }
  .now-figure {
    position: relative;
    margin: 0 auto 1.6rem;
    max-width: 420px;
  }
  .now-figure :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-rule);
    box-shadow:
      inset 0 0 0 3px var(--color-paper),
      inset 0 0 0 4px color-mix(in oklab, var(--color-rule) 45%, transparent);
  }
  /* floating label that fades in over the engraving on hover */
  .now-figcap {
    position: absolute;
    left: 50%;
    bottom: 0.85rem;
    width: max-content;
    max-width: min(90%, 22rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.7rem 1rem;
    text-align: center;
    background: color-mix(in oklab, var(--color-paper) 94%, transparent);
    border: 1px solid var(--color-rule);
    box-shadow:
      inset 0 0 0 2px var(--color-paper),
      0 8px 20px rgba(0, 0, 0, 0.22);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 8px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
  }
  .now-figure:hover .now-figcap,
  .now-figure:focus-within .now-figcap {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .now-figcap .cap-t {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .now-figcap .cap-d {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--color-ink-soft);
  }
  .now-figcap .cap-m {
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--text-label);
    color: var(--color-ink-faint);
  }
  .now-intro {
    text-align: center;
    font-style: italic;
    color: var(--color-ink-faint);
    max-width: 48ch;
    margin: 0 auto;
  }
  .now-intro a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--color-accent) 45%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .now-intro a:hover {
    text-decoration-color: var(--color-accent);
  }
  .now-updated {
    font-family: var(--font-body);
    font-variant: small-caps;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--text-label);
    color: var(--color-ink-faint);
    margin-top: 2.5rem;
  }
</style>

---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/almanac/Header.astro';
import Footer from '~/components/almanac/Footer.astro';
import RuleOrn from '~/components/almanac/RuleOrn.astro';
import Button from '~/components/almanac/Button.astro';
---

<Layout title="Not Found" description="This page could not be found." noindex>
  <Header />
  <main class="section nf">
    <div class="wrap">
      <span class="numeral" aria-hidden="true">404</span>
      <h1 class="display nf-title">A page mislaid</h1>
      <p class="nf-lede">
        This leaf appears to have been torn from the almanac, or was never bound in. No matter — the rest of the volume
        awaits.
      </p>
      <RuleOrn style="max-width:24rem;margin:1.8rem auto" />
      <Button href="/">Return to the frontispiece</Button>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .nf {
    text-align: center;
    padding-block: clamp(3rem, 9vw, 7rem);
  }
  .numeral {
    font-family: var(--font-numeral);
    font-style: italic;
    font-size: clamp(4rem, 16vw, 9rem);
    line-height: 1;
    color: var(--color-accent);
  }
  .nf-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.4rem 0 0.8rem;
  }
  .nf-lede {
    color: var(--color-ink-soft);
    max-width: 46ch;
    margin-inline: auto;
  }
</style>

{
  "skipDangerousModePermissionPrompt": true,
  "enableRemoteControl": true,
  "permissions": {
    "allow": [
      "Bash(task:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(lefthook:*)",
      "Bash(gitleaks:*)",
      "Bash(ansible-lint:*)",
      "Bash(terraform:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/block-no-verify.sh"
          },
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/enforce-conventional-commits.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/post-edit-format.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/session-start-context.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/session-start-context.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

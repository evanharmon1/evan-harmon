#!/bin/sh
# post-checkout hook: runs after branch checkouts and git worktree add.
# Chains git-lfs handling, then auto-installs Node.js dependencies when
# node_modules/ is missing (common in new worktrees).
#
# Installed by .devcontainer/post-create.sh — source of truth lives here,
# not in .git/hooks/.

# --- git-lfs ---
command -v git-lfs >/dev/null 2>&1 || {
	printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'post-checkout' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."
	exit 2
}
git lfs post-checkout "$@"

# --- auto-install Node.js dependencies ---
# $3 = 1 for branch checkout (including worktree add), 0 for file checkout.
# Only run on branch checkouts to avoid slowing down file-level operations.
# Unset NODE_OPTIONS to prevent VS Code's JS debug bootloader from crashing
# npm/pnpm/yarn — the bootloader path may not exist in this context.
unset NODE_OPTIONS 2>/dev/null || true
if [ "$3" = "1" ] && [ ! -d node_modules ]; then
	if [ -f pnpm-lock.yaml ]; then
		echo "post-checkout: node_modules missing, running pnpm install..."
		pnpm install --frozen-lockfile 2>&1 | tail -1
	elif [ -f package-lock.json ]; then
		echo "post-checkout: node_modules missing, running npm ci..."
		npm ci 2>&1 | tail -1
	elif [ -f yarn.lock ]; then
		echo "post-checkout: node_modules missing, running yarn install..."
		yarn install --frozen-lockfile 2>&1 | tail -1
	fi
fi

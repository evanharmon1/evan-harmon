# EditorConfig -- https://editorconfig.org
# This is the top-most EditorConfig file.
root = true

# ---------- Defaults ----------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ---------- Markdown / MDX ----------
# Trailing whitespace in Markdown/MDX creates <br> tags (intentional).
[*.{md,mdx}]
trim_trailing_whitespace = false

# ---------- Makefiles ----------
[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# ---------- 4-space indented languages ----------
[*.{py,tf,tfvars,sh}]
indent_size = 4

# ---------- TOML ----------
[*.toml]
indent_size = 2

# ---------- Ignore generated files ----------
[*.min.js]
insert_final_newline = false
trim_trailing_whitespace = false

{
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "permissions": {
    "additionalDirectories": [
      "../harmon-init",
      "../harmon-devkit",
      "../harmon-dotfiles",
      "../harmon-ops"
    ],
    "allow": [
      "Bash(task:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(task codex:gate:enable)",
      "Bash(task codex:gate:enable:*)",
      "Bash(task codex:gate:disable)",
      "Bash(task codex:gate:disable:*)",
      "Bash(./scripts/codex-gate.sh:*)",
      "Bash(scripts/codex-gate.sh:*)",
      "Bash(gh pr merge)",
      "Bash(gh pr merge:*)",
      "Bash(git merge)",
      "Bash(git merge:*)",
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowRead": [
        "../harmon-init",
        "../harmon-devkit",
        "../harmon-dotfiles",
        "../harmon-ops"
      ]
    }
  }
}

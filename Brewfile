# Brewfile for Evan Harmon Website
# Install with: task install  (brew bundle --file=Brewfile)

# Task runner + git hooks
brew "go-task"
brew "lefthook"

# Git / GitHub
brew "git"
brew "gh"
brew "git-delta"

# Lint / format
brew "shellcheck"
brew "shfmt"
brew "actionlint"
brew "yamllint"

# Security
brew "gitleaks"
tap "snyk/tap"
brew "snyk/tap/snyk"

# Runtime for npx-based tools (commitlint, markdownlint-cli2)
brew "node"
brew "pnpm"
brew "lychee"

# Devcontainer
brew "hadolint"

# Utilities
brew "direnv"
brew "jq"
brew "fzf"
brew "fd"
brew "ripgrep"
brew "bat"
brew "tokei"
brew "gum"          # status dashboard rendering (scripts/status.sh)
brew "television"   # interactive task menu (`task` / task menu-tv → tv)
